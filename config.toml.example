# Fune SMTP Delivery Service Configuration
#
# Hot Reload: Send SIGHUP signal to reload configuration without downtime
#   kill -HUP <pid>  OR  systemctl reload fune  OR  fune-admin reload
#
# Reloadable: source_ips, source_ip_selection, rate limits, circuit breaker, DNS, TLS certs, HTTP timeouts
# Non-reloadable: database_path, listen address, worker_count, webhook_url (require restart)

# ============================================================================
# Server Configuration
# Core server settings including database location and process management
# ============================================================================
[server]
database_path = "./queue.db"                    # SQLite database path (shared by server and admin tools)
pid_file = "fune.pid"                           # PID file location for process management

# ============================================================================
# Logging Configuration
# Configure log output level and format
# See DOCUMENTATION.md for systemd integration and best practices
# ============================================================================
[logging]
level = "info"                                  # Log level: debug, info, warn, error
format = "console"                              # Output format: console (human-readable) or json (structured)

# ============================================================================
# Inbound Configuration
# HTTP API server settings for message submission
# ============================================================================
[inbound]
listen = ":8080"                                # Listen address (port or host:port)
auth_token = "your-secret-token-here"           # API authentication token (empty = no auth)
max_body_size_bytes = 36700160                  # Max request body size (35MB default) - prevents DoS
read_timeout_seconds = 30                       # Request read timeout [HOT RELOAD]
write_timeout_seconds = 30                      # Response write timeout [HOT RELOAD]
idle_timeout_seconds = 120                      # Keep-alive idle timeout [HOT RELOAD]

# Rate limiting per IP address (token bucket algorithm)
rate_limit_enabled = false                      # Enable HTTP rate limiting (recommended for production)
rate_limit_requests_per_ip = 100                # Maximum requests per IP address per window
rate_limit_window_seconds = 60                  # Time window in seconds (default: 60s = 100 req/min)

# Idempotency prevents duplicate message delivery
idempotency_enabled = false                     # Enable idempotency key support
idempotency_header = "X-Idempotency-Key"        # HTTP header name for idempotency key
idempotency_ttl_hours = 24                      # How long to remember idempotency keys

# ============================================================================
# TLS/HTTPS Configuration
# Enable HTTPS with either file-based certificates or automatic Let's Encrypt
# See DOCUMENTATION.md for detailed TLS setup instructions
# ============================================================================
[tls]
enabled = false                                 # Enable HTTPS/TLS
provider = "file"                               # TLS provider: "file" or "letsencrypt"

# File-based certificates (for provider="file")
# Certificate and key files are loaded from the specified paths
# Supports hot reload: certificates are automatically reloaded when files change
cert_file = "/path/to/cert.pem"                 # Full path to PEM-encoded certificate file
key_file = "/path/to/key.pem"                   # Full path to PEM-encoded private key file

# Let's Encrypt automatic certificate management
# Supports two storage backends: "file" (single-node) or "s3" (multi-node cluster)
# Requires: ports 80 and 443 accessible for ACME HTTP-01 challenges
[tls.letsencrypt]
email = "admin@example.com"                     # Email for Let's Encrypt notifications
domains = ["mail.example.com"]                  # Domains for certificate (supports multiple)
storage_provider = "s3"                         # Certificate storage: "file" or "s3" (default: s3)

# File storage backend (for single-node deployments)
# Certificates stored locally on filesystem using autocert.DirCache
# Directory created automatically with 0700 permissions if it doesn't exist
# Does NOT require gossip.enabled = true
cache_dir = "./letsencrypt-cache"               # Local directory for certificate cache (default: ./letsencrypt-cache)

# S3 storage backend (for multi-node cluster deployments)
# Requires: gossip.enabled = true for leader-based coordination
# All cluster nodes read from S3; leader node handles ACME challenges and renewals
[tls.letsencrypt.s3]
bucket = "fune-tls-certificates"                # S3 bucket for certificate storage
region = "us-east-1"                            # AWS region (optional)
# access_key_id = ""                            # AWS credentials (optional, uses default chain)
# secret_access_key = ""                        # AWS secret (optional)

# ============================================================================
# Metrics Configuration
# Prometheus metrics endpoint for monitoring
# ============================================================================
[metrics]
enabled = true                                  # Enable Prometheus metrics endpoint
path = "/metrics"                               # Metrics endpoint path
username = "admin"                              # HTTP Basic Auth username (recommended for production)
password = "secure-random-password"             # HTTP Basic Auth password (use strong password)

# ============================================================================
# Health Check Configuration
# Health endpoint for cluster status, queue stats, and system health
# ============================================================================
[health]
enabled = true                                  # Enable health check endpoint
listen_addr = ":8080"                           # Health endpoint listen address
username = ""                                   # HTTP Basic Auth username (optional)
password = ""                                   # HTTP Basic Auth password (optional)

# ============================================================================
# Queue Configuration
# Message queue processing and worker settings
# ============================================================================
[queue]
worker_count = 10                               # Concurrent delivery workers per instance
batch_size = 5                                  # Messages to process per worker iteration
cleanup_interval_seconds = 60                   # How often to cleanup expired messages
poll_interval_seconds = 30                      # Fallback poll interval (uses notifications when available)

# ============================================================================
# DNS Configuration
# DNS resolver settings for MX record lookups
# ============================================================================
[dns]
resolvers = ["8.8.8.8:53", "[2001:4860:4860::8888]:53"]  # DNS servers (empty = system default)
timeout_seconds = 5                             # DNS query timeout
cache_ttl_seconds = 3600                        # Cache successful lookups (1 hour) [HOT RELOAD]
cache_negative_ttl_seconds = 60                 # Cache failed lookups (1 minute) [HOT RELOAD]

# ============================================================================
# Outbound Configuration
# SMTP delivery settings including source IPs, timeouts, and retry logic
# ============================================================================
[outbound]
# Source IP configuration [HOT RELOAD]
source_ips = ["192.168.1.100", "192.168.1.101", "2001:db8::1"]  # Outbound IPs (supports IPv4/IPv6)
source_ip_selection = "round-robin"             # IP selection: "round-robin", "random", "hash-domain" [HOT RELOAD]

# Connection settings
mx_cache_ttl_seconds = 3600                     # Cache MX records (1 hour)
connection_timeout_seconds = 30                 # TCP connection timeout
smtp_timeout_seconds = 60                       # SMTP command timeout
max_ips_per_mx = 5                              # Max IPs to try per MX host (anti-abuse)

# Rate limiting [HOT RELOAD]
per_domain_interval_seconds = 2                 # Minimum seconds between deliveries to same domain
per_domain_retry_seconds = 5                    # Delay before retrying rate-limited delivery

# Circuit breaker [HOT RELOAD]
circuit_breaker_enabled = true                  # Enable circuit breaker (stops accepting requests during failures)
circuit_breaker_failure_threshold = 5           # Consecutive failures before opening circuit
circuit_breaker_success_threshold = 2           # Consecutive successes to close circuit
circuit_breaker_open_timeout_seconds = 60       # Seconds to wait before trying half-open state

# Retry configuration
max_message_age_hours = 48                      # Maximum message age before giving up
initial_retry_delay_seconds = 300               # Initial retry delay (5 minutes)
max_retry_delay_seconds = 43200                 # Maximum retry delay (12 hours)
backoff_multiplier = 2.0                        # Exponential backoff multiplier
greylist_retry_delay_seconds = 120              # Retry delay for 421 greylist responses (2 minutes)

# ============================================================================
# Callback Configuration
# Webhook callbacks for delivery status notifications
# ============================================================================
[callbacks]
webhook_url = "https://worker.example.com/api/delivery-event"  # Webhook URL for delivery events
auth_token = "webhook-secret-token"             # Webhook authentication token
timeout_seconds = 10                            # Webhook request timeout
max_callback_age_hours = 48                     # Maximum age before giving up on callback
initial_retry_delay_seconds = 30                # Initial retry delay
max_retry_delay_seconds = 3600                  # Maximum retry delay (1 hour)
backoff_multiplier = 2.0                        # Exponential backoff multiplier
batch_size = 10                                 # Callbacks to process per iteration

# Circuit breaker for webhook failures
circuit_breaker_enabled = true                  # Enable circuit breaker for webhook
circuit_breaker_failure_threshold = 5           # Consecutive network failures before opening
circuit_breaker_success_threshold = 2           # Consecutive successes to close
circuit_breaker_open_timeout_seconds = 60       # Seconds to wait before trying half-open

# ============================================================================
# IP Reputation Configuration
# Track and manage IP reputation to avoid blacklisting
# See DOCUMENTATION.md for reputation alert payload schema
# ============================================================================
[reputation]
enable_ip_tracking = true                       # Enable IP reputation tracking
alert_webhook_url = "https://worker.example.com/api/reputation-alert"  # Reputation alert webhook
alert_auth_token = "alert-secret-token"         # Alert webhook auth token
alert_timeout_seconds = 10                      # Alert request timeout
degraded_retry_hours = 48                       # Hours before retrying degraded IP
degraded_ip_cleanup_hours = 168                 # Hours to keep degraded IP history (7 days)

# ============================================================================
# Cluster Configuration
# Distributed coordination using gossip protocol (HashiCorp memberlist)
# See DOCUMENTATION.md for multi-node setup examples and features
# ============================================================================
[cluster]
enabled = false                                 # Enable cluster mode
bind_addr = "0.0.0.0"                           # Gossip protocol bind address
bind_port = 7946                                # Gossip protocol port
node_id = ""                                    # Unique node ID (defaults to hostname)
peers = ["fune-1", "fune-2"]                    # Initial seed nodes (only need 1-2, gossip discovers others)
secret_key = "your-base64-encoded-32-byte-secret-key-here"  # Cluster encryption key (required for production)

# ============================================================================
# ARC Configuration
# Authenticated Received Chain (RFC 8617) for email forwarding
# Preserves authentication results across forwarding hops to prevent DMARC failures
# See DOCUMENTATION.md for ARC setup, key generation, and DNS record configuration
# ============================================================================
[arc]
enabled = false                                 # Enable ARC signing (essential for email forwarding)
selector = "arc-2024"                           # DNS selector for ARC public key (e.g., arc-2024._domainkey.example.com)
domain = "example.com"                          # Domain for ARC signing (must match your mail server domain)
private_key_path = "/etc/fune/keys/arc-private.pem"  # Path to RSA private key (1024 or 2048 bits, PEM format)
header_canon = "relaxed"                        # Header canonicalization: "relaxed" or "simple" (default: relaxed) [HOT RELOAD]
body_canon = "relaxed"                          # Body canonicalization: "relaxed" or "simple" (default: relaxed) [HOT RELOAD]

# Generate RSA key pair for ARC:
#   openssl genrsa -out arc-private.pem 2048
#   openssl rsa -in arc-private.pem -pubout -out arc-public.pem
#
# Extract public key for DNS TXT record:
#   openssl rsa -in arc-private.pem -pubout -outform PEM | grep -v "PUBLIC KEY" | tr -d '\n'
#
# DNS TXT record (add to your domain's DNS):
#   arc-2024._domainkey.example.com. IN TXT "v=DKIM1; k=rsa; p=MIIBIjANBgkq..."
#
# Why use ARC:
#   - Prevents SPF/DKIM failures when forwarding authenticated emails
#   - Essential for mailing lists, email forwarding services, and mail relays
#   - Records authentication results from previous hops in the chain
#   - Without ARC, forwarded messages may fail DMARC checks at destination

# ============================================================================
# SRS Configuration
# Sender Rewriting Scheme (SRS) for envelope sender rewriting
# Prevents SPF failures when forwarding email by rewriting MAIL FROM addresses
# See DOCUMENTATION.md for SRS setup, bounce handling, and security considerations
# ============================================================================
[srs]
enabled = false                                 # Enable SRS envelope rewriting (essential for email forwarding)
domain = "mail.example.com"                     # Domain for rewritten addresses (use your mail server domain)
secret = "your-secure-random-secret-min-16-chars"  # Secret for HMAC hash (KEEP SECURE, min 16 chars)
max_age = 21                                    # Maximum age in days for SRS addresses (default: 21) [HOT RELOAD]
hash_length = 4                                 # Length of hash in SRS address (2-8, default: 4) [HOT RELOAD]
separator = "="                                 # Separator character (default: "=") [HOT RELOAD]
always_rewrite = false                          # Always rewrite all senders, not just when forwarding (default: false) [HOT RELOAD]

# How SRS works:
#   Original MAIL FROM:  user@example.com
#   Rewritten:           SRS0=HASH=TT=example.com=user@mail.example.com
#
# The rewritten address:
#   - Uses your domain (passes SPF checks with your IPs)
#   - Encodes original sender (for bounce routing)
#   - Includes timestamp (prevents replay attacks)
#   - Has HMAC hash (prevents forgery)
#
# Generate a strong secret:
#   openssl rand -base64 32
#
# Why use SRS:
#   - Prevents SPF failures when forwarding email
#   - Essential for mail forwarding, mailing lists, and relay services
#   - Without SRS, forwarded messages fail SPF at destination
#   - Enables proper bounce handling back to original sender
#
# Security considerations:
#   - Use a strong random secret (min 16 chars, recommended 32+)
#   - Keep the secret secure and rotate periodically
#   - Set appropriate max_age to limit address validity
#   - SRS addresses are meant for temporary use (bounces)
