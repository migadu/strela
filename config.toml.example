# Strela v2.0 Configuration Example
# Synchronous SMTP Delivery Gateway
# Copy to config.toml and adjust as needed.
#
# IMPORTANT: v2.0 is a synchronous delivery model
# - HTTP requests block until SMTP delivery completes (or times out)
# - Caller MUST implement queue + retry logic
# - No database/queue managed by Strela

[logging]
output = "stderr"    # stderr, stdout, syslog, or /path/to/file.log
format = "console"   # console (human-readable), json (structured)
level = "info"       # debug, info, warn, error

[inbound]
listen = ":443"
auth_token = "change-me-in-production"  # Bearer token for API authentication
max_body_size_bytes = 36700160          # 35MB (maximum message size)

# Timeouts - IMPORTANT for synchronous model
read_timeout_seconds = 30               # Time to read request body
write_timeout_seconds = 240             # MUST be > max_total_delivery_seconds + margin (default: 200s)
idle_timeout_seconds = 120              # Keep-alive timeout

# Rate limiting (per source IP)
rate_limit_enabled = false
rate_limit_requests_per_ip = 100
rate_limit_window_seconds = 60

# Concurrency limiting - CRITICAL for preventing overload
max_concurrent_requests = 200           # Maximum concurrent HTTP requests (0 = unlimited)
                                        # When limit reached: returns 503 Service Unavailable
                                        # Recommended: 100-500 depending on available resources
                                        # Each request holds a goroutine + network connections

[tls]
enabled = false
# provider = "file"                      # "file" or "letsencrypt"
# cert_file = "/etc/ssl/certs/mail.pem"  # For provider = "file"
# key_file = "/etc/ssl/private/mail.key" # For provider = "file"

[tls.letsencrypt]
# email = "admin@example.com"
# domains = ["mail.example.com"]
# storage_provider = "file"              # "file" (single node) or "s3" (hybrid local+S3 for cluster)
# cache_dir = "/var/lib/strela/letsencrypt" # Local cache directory (required for both "file" and "s3" modes)
# sync_interval_minutes = 5               # Sync local cache to S3 every N minutes (default: 5, only for storage_provider="s3")
                                          # Only changed/missing certificates are uploaded (smart sync)

[tls.letsencrypt.s3]
# Required for storage_provider = "s3"
# When using S3, certificates are stored locally for fast TLS handshakes
# and periodically synced to S3 for backup and cluster sharing
# bucket = "strela-letsencrypt"
# region = "us-east-1"
# endpoint = ""                                  # Optional: Custom S3 endpoint (e.g., "https://s3.us-west-004.backblazeb2.com" for Backblaze B2)
# prefix = ""                                    # Base prefix for all S3 keys (e.g., "myapp" or "myapp/" → myapp/certs/, myapp/stats/, myapp/connections/)
#                                                # Leading slashes are stripped, trailing slash is added automatically
#                                                # Examples: "myapp", "/myapp", "myapp/" all become "myapp/"
#                                                # Subdirectories are appended automatically. Do NOT use "certs/" here — it would create "certs/certs/"
# access_key = "AKIAIOSFODNN7EXAMPLE"
# secret_key = "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"

[dns]
# Custom DNS resolvers (optional - uses system default if not specified)
# resolvers = ["8.8.8.8:53", "1.1.1.1:53"]  # Supports IPv6: ["2001:4860:4860::8888:53"]
timeout_seconds = 5                         # DNS query timeout
cache_ttl_seconds = 3600                    # Cache successful MX lookups (1 hour)
cache_negative_ttl_seconds = 60             # Cache failed MX lookups (1 minute)

[metrics]
enabled = true
path = "/metrics"                           # Prometheus metrics endpoint path (served on admin server)

[admin]
# Admin server: serves /health and /metrics on a separate localhost-only listener.
# Not exposed publicly — use strela-admin to query from the local machine.
enabled = true
bind = "127.0.0.1:8080"                    # Localhost-only admin server (health + metrics)
# username = "admin"                        # Optional basic auth
# password = "secure-password"

[outbound]
# Source IP configuration - supports individual IPs and CIDR subnets
# Examples: "192.0.2.1", "192.0.2.0/28" (16 IPs), "2001:db8::1", "2001:db8::/124" (16 IPs)
# Subnets are expanded on startup. Limits: IPv4 max /22 (1024 IPs), IPv6 max /120 (256 IPs)

# IPv6-first delivery (recommended for better deliverability and modern infrastructure)
prefer_ipv6 = true                          # Try IPv6 first, fall back to IPv4 if unavailable

# Separate IPv4 and IPv6 source IP pools
source_ips_v4 = ["192.0.2.1", "192.0.2.2"]  # IPv4 source IPs/subnets
source_ips_v6 = ["2001:db8::1"]             # IPv6 source IPs/subnets

source_ip_selection = "round-robin"         # "round-robin", "random", or "hash-domain"
mx_cache_ttl_seconds = 3600                 # In-memory MX record cache TTL
max_ips_per_mx = 5                          # Max IP addresses to try per MX host

# SMTP connection settings
connection_timeout_seconds = 15             # TCP connection timeout to MX server
banner_timeout_seconds = 30                 # Timeout for SMTP banner (220 greeting) - some MX servers are slow
handshake_timeout_seconds = 30              # Timeout for EHLO/HELO + STARTTLS handshake
smtp_timeout_seconds = 60                   # SMTP command timeout for MAIL/RCPT/DATA commands
connection_pool_ttl_seconds = 5             # Max time to keep idle connection for reuse
hello_hostname = "mail.example.com"         # Hostname for EHLO greeting (default: system hostname)

# v2.0.7 TOTAL DELIVERY TIMEOUT - CRITICAL SETTING
max_total_delivery_seconds = 200            # HARD CAP for entire delivery operation across ALL attempts
                                            # Includes: DNS + all MX servers + all source IPs + retries
                                            # HTTP response will block for up to this duration
                                            # Recommended: 120-300s for production (some MX servers are very slow)
                                            # NOTE: inbound.write_timeout_seconds must be > this value
                                            #
                                            # Per-attempt phase timeouts (will be scaled if remaining time is less):
                                            #   - TCP connection: 15s (connection_timeout_seconds)
                                            #   - SMTP banner: 30s (banner_timeout_seconds)
                                            #   - Handshake: 30s (handshake_timeout_seconds)
                                            #   - Delivery: 60s (smtp_timeout_seconds)
                                            # Single attempt ideal: 135s
                                            # Multiple MX/IPs could exceed → max_total_delivery_seconds caps it

# Per-domain rate limiting - CRITICAL for preventing MX server abuse
per_domain_interval_seconds = 2             # Minimum seconds between deliveries to same domain
                                            # Prevents hammering recipient MX servers
per_domain_burst = 10                       # Burst size (allow X concurrent starts before rate limiting)
                                            # "Fail Fast": If exceeded, returns 429 Too Many Requests
per_domain_retry_seconds = 5                # Delay before retrying rate-limited delivery (deprecated in v2.0)
# rate_limit_whitelist = ["example.com", "trusted-domain.net"]  # Domains exempt from rate limiting

[reputation]
enable_ip_tracking = false                  # Track and rotate out degraded source IPs
# alert_webhook_url = "https://hooks.slack.com/..."  # Webhook for IP degradation alerts
degraded_retry_hours = 48                   # Hours before retrying degraded IP
degraded_ip_cleanup_hours = 168             # Hours before removing from degraded list (7 days)

[cluster]
# Optional - only needed for Let's Encrypt with S3 storage
enabled = false
# bind = "0.0.0.0"                              # Can be "IP:port" or just "IP" (default: 0.0.0.0)
# port = 7946                                    # Gossip port, used if not specified in bind (default: 7946)
# secret_key = "base64-encoded-32-byte-key"    # Generate: openssl rand -base64 32
# peers = ["node2:7946", "node3:7946"]

[dkim]
# DKIM (DomainKeys Identified Mail) signing for outbound messages
# IMPORTANT: enabled=true is REQUIRED for DKIM to be applied (even if API provides parameters)
enabled = false
# selector = "default"                           # DNS selector for DKIM public key (e.g., "default", "mail")
# domain = "example.com"                         # Domain for DKIM signing (e.g., "example.com")
# private_key_path = "/etc/strela/dkim-private.key" # Path to RSA private key in PEM format (1024 or 2048 bits)
# skip_validation = false                        # Skip DNS validation of DKIM record (default: false, faster but less safe)
# header_canon = "relaxed"                       # Header canonicalization: "relaxed" or "simple" (default: relaxed)
# body_canon = "relaxed"                         # Body canonicalization: "relaxed" or "simple" (default: relaxed)

# API request behavior:
# - If enabled=true: API parameters (dkim_private_key, dkim_selector, dkim_domain) override config defaults
# - If enabled=false: All API DKIM parameters are IGNORED (logged as warning)
# Security: The enabled flag acts as a master switch - API cannot bypass it

[arc]
# Authenticated Received Chain (ARC) signing for email forwarding
# Preserves authentication results across forwarding hops (prevents DMARC failures)
# IMPORTANT: enabled=true is REQUIRED for ARC to be applied (even if API provides parameters)
enabled = false
# selector = "arc"
# domain = "example.com"
# private_key_path = "/etc/strela/arc-private.key"
# header_canon = "relaxed"                       # Header canonicalization (default: relaxed)
# body_canon = "relaxed"                         # Body canonicalization (default: relaxed)

# API request behavior (same as DKIM):
# - If enabled=true: API parameters (arc_private_key, arc_selector, arc_domain) override config defaults
# - If enabled=false: All API ARC parameters are IGNORED (logged as warning)
# Security: The enabled flag acts as a master switch - API cannot bypass it

[srs]
# Sender Rewriting Scheme (SRS) for envelope sender rewriting
# Rewrites MAIL FROM to prevent SPF failures when forwarding
# Multi-domain support helps avoid rate limiting from providers like Gmail
enabled = false
# domains = [                                    # List of domains for SRS addresses (rotated to distribute volume)
#   "srs1.example.com",
#   "srs2.example.com",
#   "srs3.example.com",
#   "srs1.example.org",
#   "srs2.example.org",
#   "srs3.example.org"
# ]
# selection = "round-robin"                      # Domain selection: "round-robin" (even distribution) or "hash-sender" (consistent per sender)
# secret = "change-me-to-something-secure"       # Secret key for HMAC hash (min 16 chars, shared across all domains)
# max_age = 21                                   # Maximum age in days for SRS addresses (default: 21)
# hash_length = 4                                # Length of hash in SRS address (default: 4, range: 2-8)
# separator = "="                                # Separator character (default: "=")
# skip_domains = ["gmail.com", "googlemail.com"] # Destination domains that should NOT receive SRS-rewritten senders
# skip_if_dkim_pass = false                       # Skip SRS when caller reports dkim_result="pass" (message was DKIM-authenticated at the forwarder)
# skip_if_same_domain = false                     # Skip SRS when sender domain matches recipient domain (intra-domain forwarding)
# use_dynamic_subdomain = false                   # Prepend sanitized sender domain as subdomain of the selected SRS domain
#                                                 # e.g. sender "user@outlook.com" + base "srs.example.com" → "outlook-com.srs.example.com"
#                                                 # Requires wildcard DNS: *.srs.example.com → your server

# IMPORTANT: All SRS domains must:
# - Point to your mail server (MX records) to receive bounces
# - Have matching SPF records
# - Optionally have DKIM configured
# - Share the same secret for bounce decoding
