# Fune v2.0 Configuration Example
# Synchronous SMTP Delivery Gateway
# Copy to config.toml and adjust as needed.
#
# IMPORTANT: v2.0 is a synchronous delivery model
# - HTTP requests block until SMTP delivery completes (or times out)
# - Caller MUST implement queue + retry logic
# - No database/queue managed by Fune

[logging]
output = "stderr"    # stderr, stdout, syslog, or /path/to/file.log
format = "console"   # console (human-readable), json (structured)
level = "info"       # debug, info, warn, error

[inbound]
listen = ":443"
auth_token = "change-me-in-production"  # Bearer token for API authentication
max_body_size_bytes = 36700160          # 35MB (maximum message size)

# Timeouts - IMPORTANT for synchronous model
read_timeout_seconds = 30               # Time to read request body
write_timeout_seconds = 90              # MUST be > delivery_timeout_seconds + margin
idle_timeout_seconds = 120              # Keep-alive timeout

# Rate limiting (per source IP)
rate_limit_enabled = false
rate_limit_requests_per_ip = 100
rate_limit_window_seconds = 60

# Concurrency limiting - CRITICAL for preventing overload
max_concurrent_requests = 200           # Maximum concurrent HTTP requests (0 = unlimited)
                                        # When limit reached: returns 503 Service Unavailable
                                        # Recommended: 100-500 depending on available resources
                                        # Each request holds a goroutine + network connections

[tls]
enabled = false
# provider = "file"                      # "file" or "letsencrypt"
# cert_file = "/etc/ssl/certs/mail.pem"  # For provider = "file"
# key_file = "/etc/ssl/private/mail.key" # For provider = "file"

[tls.letsencrypt]
# email = "admin@example.com"
# domains = ["mail.example.com"]
# storage_provider = "file"              # "file" (single node) or "s3" (cluster)
# cache_dir = "/var/lib/fune/letsencrypt" # For storage_provider = "file"

[tls.letsencrypt.s3]
# Required for storage_provider = "s3"
# bucket = "fune-letsencrypt"
# region = "us-east-1"
# endpoint = ""                                  # Optional: Custom S3 endpoint (e.g., "s3.us-west-004.backblazeb2.com" for Backblaze B2)
# access_key = "AKIAIOSFODNN7EXAMPLE"
# secret_key = "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"

[dns]
# Custom DNS resolvers (optional - uses system default if not specified)
# resolvers = ["8.8.8.8:53", "1.1.1.1:53"]  # Supports IPv6: ["2001:4860:4860::8888:53"]
timeout_seconds = 5                         # DNS query timeout
cache_ttl_seconds = 3600                    # Cache successful MX lookups (1 hour)
cache_negative_ttl_seconds = 60             # Cache failed MX lookups (1 minute)

[metrics]
enabled = true
path = "/metrics"                           # Prometheus metrics endpoint
# username = "admin"                        # Optional basic auth
# password = "secure-password"

[health]
enabled = true
listen_addr = ":8080"                       # Health check endpoint (separate from main API)

[outbound]
# Source IP configuration - supports individual IPs and CIDR subnets
# Examples: "192.0.2.1", "192.0.2.0/28" (16 IPs), "2001:db8::1", "2001:db8::/124" (16 IPs)
# Subnets are expanded on startup. Limits: IPv4 max /22 (1024 IPs), IPv6 max /120 (256 IPs)

# IPv6-first delivery (recommended for better deliverability and modern infrastructure)
prefer_ipv6 = true                          # Try IPv6 first, fall back to IPv4 if unavailable

# Separate IPv4 and IPv6 source IP pools
source_ips_v4 = ["192.0.2.1", "192.0.2.2"]  # IPv4 source IPs/subnets
source_ips_v6 = ["2001:db8::1"]             # IPv6 source IPs/subnets

source_ip_selection = "round-robin"         # "round-robin", "random", or "hash-domain"
mx_cache_ttl_seconds = 3600                 # In-memory MX record cache TTL
max_ips_per_mx = 5                          # Max IP addresses to try per MX host

# SMTP connection settings
connection_timeout_seconds = 30             # TCP connection timeout to MX server
connection_pool_ttl_seconds = 5             # Max time to keep idle connection for reuse
smtp_timeout_seconds = 60                   # SMTP command/response timeout

# v2.0 SYNCHRONOUS DELIVERY TIMEOUT - CRITICAL SETTING
delivery_timeout_seconds = 30               # Maximum time for entire delivery attempt
                                            # Includes: DNS lookup + TCP connect + SMTP handshake + delivery
                                            # HTTP response will block for up to this duration
                                            # Recommended: 30-60s for production
                                            # NOTE: inbound.write_timeout_seconds must be > this value

# Per-domain rate limiting - CRITICAL for preventing MX server abuse
per_domain_interval_seconds = 2             # Minimum seconds between deliveries to same domain
                                            # Prevents hammering recipient MX servers
per_domain_burst = 10                       # Burst size (allow X concurrent starts before rate limiting)
                                            # "Fail Fast": If exceeded, returns 429 Too Many Requests
per_domain_retry_seconds = 5                # Delay before retrying rate-limited delivery (deprecated in v2.0)

[reputation]
enable_ip_tracking = false                  # Track and rotate out degraded source IPs
# alert_webhook_url = "https://hooks.slack.com/..."  # Webhook for IP degradation alerts
degraded_retry_hours = 48                   # Hours before retrying degraded IP
degraded_ip_cleanup_hours = 168             # Hours before removing from degraded list (7 days)

[cluster]
# Optional - only needed for Let's Encrypt with S3 storage
enabled = false
# bind_addr = "0.0.0.0"
# bind_port = 7946
# secret_key = "base64-encoded-32-byte-key"    # Generate: openssl rand -base64 32
# peers = ["node2:7946", "node3:7946"]

[arc]
# Authenticated Received Chain (ARC) signing
enabled = false
# selector = "arc"
# domain = "example.com"
# private_key_path = "/etc/fune/arc-private.key"

[srs]
# Sender Rewriting Scheme (SRS) for forwarding
enabled = false
# domain = "mail.example.com"
# secret = "change-me-to-something-secure"
