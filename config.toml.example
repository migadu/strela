# Fune SMTP Delivery Service Configuration
#
# Hot Reload: Send SIGHUP signal to reload configuration without downtime
#   kill -HUP <pid>  OR  systemctl reload fune  OR  fune-admin reload
#
# Reloadable: source_ips, ip_selection, rate limits, circuit breaker, DNS, TLS certs, HTTP timeouts
# Non-reloadable: database_path, listen address, worker_count, webhook_url (require restart)

[server]
database_path = "./queue.db"  # SQLite database path (used by both fune-server and fune-admin)
pid_file = "fune.pid"          # Path to PID file for process management

# Logging configuration
[logging]
level = "info"      # Log level: debug, info, warn, error (default: info)
format = "console"  # Log format: console (human-readable) or json (structured)

# Logging best practices with systemd:
# - Logs always go to stdout/stderr
# - systemd's journald captures and manages logs automatically
# - No need for log rotation (journald handles it)
# - Use journalctl to view logs: journalctl -u fune -f
#
# Format options:
#   console: Human-readable with colors (good for development, journalctl -u fune -f)
#   json:    Structured JSON (good for log aggregation: ELK, Loki, Splunk)
#
# Production with systemd:
#   level = "info"
#   format = "json"  # Structured logging for journald
#
# Development:
#   level = "debug"
#   format = "console"  # Easy to read
#
# View logs:
#   journalctl -u fune -f                    # Follow logs
#   journalctl -u fune --since "1 hour ago"  # Last hour
#   journalctl -u fune -o json-pretty        # JSON output

[http]
listen = ":8080"
auth_token = "your-secret-token-here"  # Leave empty to disable authentication
max_body_size_bytes = 36700160         # 35 MB - prevents DoS from large requests
read_timeout_seconds = 30              # Maximum time to read request (default: 30s) [HOT RELOAD]
write_timeout_seconds = 30             # Maximum time to write response (default: 30s) [HOT RELOAD]
idle_timeout_seconds = 120             # Maximum idle time for keep-alive (default: 120s) [HOT RELOAD]

# TLS/HTTPS configuration [CERTIFICATES AUTO-RELOAD ON EACH CONNECTION]
tls_enabled = false                    # Enable HTTPS with TLS
tls_cert_file = "/path/to/cert.pem"    # TLS certificate file (required if tls_enabled)
tls_key_file = "/path/to/key.pem"      # TLS private key file (required if tls_enabled)
# Example with Let's Encrypt:
# tls_cert_file = "/etc/letsencrypt/live/example.com/fullchain.pem"
# tls_key_file = "/etc/letsencrypt/live/example.com/privkey.pem"
# Note: Certificates reload automatically - just replace files, no SIGHUP needed!

# Metrics configuration
metrics_enabled = true                 # Enable Prometheus metrics endpoint (recommended for production)
metrics_path = "/metrics"              # Path for metrics endpoint (default: /metrics)

# Idempotency configuration (prevents duplicate message delivery)
idempotency_enabled = false            # Enable idempotency key support (default: false)
idempotency_header = "X-Idempotency-Key"  # Header name for idempotency key (default: X-Idempotency-Key)
idempotency_ttl_hours = 24             # How long to keep idempotency keys in hours (default: 24)
# When enabled, clients can send X-Idempotency-Key header to prevent duplicate deliveries
# Same key within TTL period returns existing message_id with 202 Accepted (idempotent response)
# Keys are automatically cleaned up after TTL expires
# Recommended for use with HAProxy consistent hashing: balance hdr(X-Idempotency-Key)

[queue]
worker_count = 10               # Concurrent delivery workers per instance
batch_size = 5                  # Messages to process per worker iteration
cleanup_interval_seconds = 60   # How often to check for expired messages
poll_interval_seconds = 30      # Fallback poll interval (workers are notified immediately)

[delivery]
# Multiple source IPs for outbound delivery (supports both IPv4 and IPv6) [HOT RELOAD]
# IPv6 addresses should be in standard notation
source_ips = ["192.168.1.100", "192.168.1.101", "2001:db8::1"]
ip_selection = "round-robin"   # Options: "round-robin", "random", "hash-domain" [HOT RELOAD]
# Note: Delivery attempts IPv6 first, then falls back to IPv4

# MX lookup and connection settings
mx_cache_ttl_seconds = 3600        # Cache MX records for 1 hour (successful lookups)
connection_timeout_seconds = 30
smtp_timeout_seconds = 60
max_ips_per_mx = 5                 # Maximum IPs to try per MX host (protects against malicious multihomed hosts)

# Rate limiting per destination domain (prevents spam-like behavior)
per_domain_interval_seconds = 2  # Minimum seconds between deliveries to same domain
per_domain_retry_seconds = 5     # Retry delay when rate-limited

# Circuit breaker configuration (stops accepting requests during delivery failures)
circuit_breaker_enabled = true            # Enable circuit breaker (recommended for production)
circuit_breaker_failure_threshold = 5     # Consecutive local failures before opening circuit
circuit_breaker_success_threshold = 2     # Consecutive successes in half-open to close circuit
circuit_breaker_open_timeout_seconds = 60 # Seconds to wait before trying half-open state

# DNS resolver configuration
# Custom DNS servers for MX lookups (optional, uses system default if not specified)
# Supports both IPv4 and IPv6 DNS servers (IPv6 must use bracket notation)
dns_resolvers = ["8.8.8.8:53", "[2001:4860:4860::8888]:53"]  # Google DNS (IPv4 and IPv6)
# dns_resolvers = ["1.1.1.1:53", "[2606:4700:4700::1111]:53"]  # Cloudflare DNS (IPv4 and IPv6)
# dns_resolvers = []  # Empty to use system default resolver
dns_timeout_seconds = 5            # Timeout for individual DNS queries
dns_cache_negative_ttl = 60        # Cache failed lookups (NXDOMAIN) for 1 minute
# Note: DNS resolver automatically queries both AAAA (IPv6) and A (IPv4) records

# Retry configuration
max_message_age_hours = 48
initial_retry_delay_seconds = 300      # 5 minutes
max_retry_delay_seconds = 43200        # 12 hours
backoff_multiplier = 2.0
greylist_retry_delay_seconds = 120     # 2 minutes for 421 responses

[callbacks]
webhook_url = "https://worker.example.com/api/delivery-event"
auth_token = "webhook-secret-token"
timeout_seconds = 10
max_callback_age_hours = 48            # Maximum age before giving up (same as message age)
initial_retry_delay_seconds = 30       # Initial retry delay (30 seconds)
max_retry_delay_seconds = 3600         # Maximum retry delay (1 hour) - caps exponential backoff
backoff_multiplier = 2.0               # Exponential backoff multiplier (doubles each retry)
batch_size = 10                        # Callbacks to process per iteration

# Callback retry pattern: 30s, 60s, 120s, 240s, 480s, 960s, 1800s, 3600s (max), ...
# Total retries depend on max_callback_age_hours - retries until age exceeds limit

[reputation]
# IP reputation tracking and alerting
# When an IP fails delivery due to blacklisting or poor reputation, it's marked as "degraded"
# and temporarily removed from the rotation pool
enable_ip_tracking = true              # Enable IP reputation tracking (default: true)
alert_webhook_url = "https://worker.example.com/api/reputation-alert"  # URL for reputation alerts
alert_auth_token = "alert-secret-token"  # Auth token for alert webhook (optional)
alert_timeout_seconds = 10             # Timeout for alert requests (default: 10)
degraded_retry_hours = 48              # Hours before retrying degraded IP (default: 48)
degraded_ip_cleanup_hours = 168        # Hours to keep degraded IP history - 7 days (default: 168)

# Reputation alert payload (sent as JSON POST):
# {
#   "timestamp": "2024-01-15T10:30:00Z",
#   "source_ip": "192.168.1.100",
#   "event_type": "degraded" or "recovered",
#   "from": "sender@example.com",
#   "to": "recipient@example.com",
#   "subject": "Message subject",
#   "idempotency_key": "abc123" (if provided),
#   "smtp_code": 550,
#   "smtp_response": "IP blocked by Spamhaus",
#   "mx_host": "mx.example.com",
#   "retry_after": "2024-01-17T10:30:00Z",
#   "degraded_ips_count": 1
# }
#
# When an IP is degraded:
# - It's removed from the delivery rotation pool
# - Alert webhook is called with event_type="degraded"
# - IP is retried after degraded_retry_hours (default: 48 hours)
# - If retry succeeds, alert webhook is called with event_type="recovered"
# - If retry fails, IP remains degraded for another degraded_retry_hours period

[gossip]
# Gossip protocol configuration for distributed coordination across multiple fune instances
# Uses HashiCorp memberlist for cluster membership and state sharing
enabled = false                                    # Enable gossip protocol (default: false)
bind_port = 7946                                   # Port for gossip protocol (default: 7946)
join_addresses = ["fune-1:7946", "fune-2:7946"]   # Initial seed nodes to join the cluster
node_id = ""                                       # Unique node identifier (defaults to hostname)

# Features enabled by gossip protocol:
# 1. Distributed Idempotency (best-effort):
#    - When a message is accepted with an idempotency key, the key is broadcast to the cluster
#    - Other nodes check the gossip cache before accepting duplicate requests
#    - Returns HTTP 409 Conflict if key is claimed by another node
#    - Provides real-time duplicate detection across the cluster
#    - Note: This is best-effort and may not catch all duplicates in race conditions
#
# 2. Cluster-wide Load Monitoring:
#    - Each node broadcasts its queue depth, active workers, and uptime every 10 seconds
#    - Cluster status available via /admin/cluster/status endpoint
#    - Use fune-admin cluster-status -server http://any-node:8080 to view cluster health
#
# Example multi-node setup:
#   Node 1 (fune-1):
#     enabled = true
#     bind_port = 7946
#     join_addresses = ["fune-2:7946", "fune-3:7946"]  # Other nodes in cluster
#     node_id = "fune-1"
#
#   Node 2 (fune-2):
#     enabled = true
#     bind_port = 7946
#     join_addresses = ["fune-1:7946", "fune-3:7946"]
#     node_id = "fune-2"
#
# Recommended use with load balancer:
#   - HAProxy with consistent hashing: balance hdr(X-Idempotency-Key)
#   - This directs requests with the same idempotency key to the same node
#   - Gossip provides additional safety for race conditions and failover scenarios
